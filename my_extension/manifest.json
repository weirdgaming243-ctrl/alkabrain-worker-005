{
   "action": {
      "default_icon": {
         "19": "img/icon19.png",
         "38": "img/icon38.png"
      },
      "default_popup": "html/browser_popup.html",
      "default_title": "Hunter"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "js/lib/jquery.min.js", "js/shared.js", "js/hunter_content_script.js" ],
      "matches": [ "*://*.hunter.io/*" ]
   }, {
      "css": [ "css/websites-sources.css" ],
      "js": [ "js/lib/jquery.min.js", "js/lib/purify.min.js", "js/shared.js", "js/websites_content_script.js" ],
      "matches": [ "*://*/*" ]
   } ],
   "default_locale": "en",
   "description": "__MSG_extension_description__",
   "homepage_url": "https://hunter.io",
   "host_permissions": [ "https://*.hunter.io/" ],
   "icons": {
      "128": "img/icon128.png",
      "16": "img/icon16.png",
      "48": "img/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_extension_name__",
   "permissions": [ "tabs", "storage" ],
   "short_name": "Hunter",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "3.1.4",
   "web_accessible_resources": [ {
      "matches": [ "*://*/*" ],
      "resources": [ "img/location_icon.png", "html/source_popup.html" ]
   } ]
}
